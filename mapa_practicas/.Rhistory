genes_unique_overlap13 <- setdiff(genes_DE_isla_sur, chen_13)
length(genes_unique_overlap13)
head(genes_unique_overlap13, 20)
# genes únicos del paper
genes_unique_chen13 <- setdiff(chen_13, genes_DE_isla_sur)
length(genes_unique_chen13)
head(genes_unique_chen13, 20)
# test hipergeométrico/ Fisher
phyper(
q = length(overlap_chen13) - 1,
m = length(chen_13),
n = total_genes - length(chen_13),
k = length(genes_DE_isla_sur),
lower.tail = FALSE
)
# añadimos todas las listas (de momento esto primero para ver como es)
listas_overlap <- list(Fig5 = fig5, Fig7 = fig7, Fig7_MB = fig7_MB, Sudhorf19 = sudhorf_19, Sudhorf23 = sudhorf_23, Marco = marco, Jaeger = jaeger, Agrawal = agrawal, Winbush = winbush, Crocker = crocker, Widmer = widmer, Chen12 = chen_12, Chen13 = chen_13, DEGs = genes_DE_isla_sur)
# convertimos a formato upset
upset_data <- fromList(listas_overlap)
# ordenamos para que salga los DEGs al final
sets_ordenados <- rev(names(listas_overlap))
# visualizamos
upset_sin_isla_sur <- upset(upset_data, sets = sets_ordenados, keep.order = TRUE, nsets = 14, order.by = "freq", main.bar.color = "steelblue", sets.bar.color = "lightgray", matrix.color = "red", text.scale = 1.5)
print(upset_sin_isla_sur)
listas_overlap <- list(
fig5 = overlap_fig5,
fig7 = overlap_fig7,
fig7_MB = overlap_fig7_MB,
marco = overlap_marco,
jaeger = overlap_jaeger,
sudhorf19 = overlap_sudhorf19,
sudhorf23 = overlap_sudhorf23,
agrawal = overlap_agrawal,
crocker = overlap_crocker,
winbush = overlap_winbush,
widmer = overlap_widmer,
chen12 = overlap_chen12,
chen13 = overlap_chen13
)
for (nombre_lista in names(listas_overlap)) {
cat("\nProcesando:", nombre_lista, "\n")
# genes del overlap (en Symbol)
genes_overlap_symbol <- listas_overlap[[nombre_lista]]
# convertir a ID usando tabla_meta_genes
genes_overlap_id <- rownames(tabla_meta_genes)[match(genes_overlap_symbol, tabla_meta_genes$Symbol)]
# eliminar los que no tienen match
genes_overlap_id <- genes_overlap_id[!is.na(genes_overlap_id)]
# filtrar genes que existen en el objeto
genes_overlap_id <- genes_overlap_id[genes_overlap_id %in% rownames(seurat_clean)]
#filtrar listas pequeñas
if (length(genes_overlap_id) < 3) {
cat("Lista demasiado pequeña. se omiten\n")
next
}
# creamos la matriz
mat_overlap <- GetAssayData(seurat_clean, slot = 'data')[genes_overlap_id, ]
# calculamos la media de cada fila (gen) y obtenemos el orden decreciente
medias_genes <- rowMeans(mat_overlap)
# Orden de mayor a menor
orden_expresion <- order(medias_genes, decreasing = TRUE)
# Seleccionar genes: si hay más de 44, tomar solo los 30 más expresados
if (length(genes_overlap_id) > 44) {
genes_overlap_id <- genes_overlap_id[orden_expresion][1:30]
} else {
# si no cumple ese tamaño dejarlo como está
genes_overlap_id <- genes_overlap_id[orden_expresion]
}
# escalamos y reordenamos la matriz
mat_overlap <- GetAssayData(seurat_clean, slot = 'data')[genes_overlap_id, ]
mat_overlap <- t(scale(t(as.matrix(mat_overlap))))
# anotación
anno_info_overlap <- data.frame(Cluster = seurat_clean$RNA_snn_res.0.5, Genotype = seurat_clean$Group,
PC1 = seurat_clean$PC1)
rownames(anno_info_overlap) <- colnames(seurat_clean)
anno_info_overlap <- anno_info_overlap[colnames(mat_overlap), ]
# colores
col_lista <- list(Cluster = c("0" = "#F8766D", "1" = "#00BA38", "2" = "#619CFF"),
Genotype = c("WT_Naive" = "#7CAE00", "CC_T" = "#E76BF3", "SC_T" = "#00BFC4", "SC_T_REACT" = "#FFD700"),
PC1 = colorRamp2(c(-60, 0, 20), c("#fff5eb", "#fdae6b", "#d94801")))
labels_genes <- tabla_meta_genes$Symbol[match(genes_overlap_id, rownames(tabla_meta_genes))]
# Heatmap por parecido celular
rder_genotypes <- c("WT_Naive", "CC_T", "SC_T", "SC_T_REACT")
orden <- order(anno_info_overlap$PC1)
mat_overlap <- mat_overlap[, orden]
anno_info_overlap <- anno_info_overlap[orden, ]
ha_overlap <- HeatmapAnnotation(df = anno_info_overlap, col = col_lista)
heatmap_overlap <- Heatmap(
mat_overlap,
name = "Expression",
top_annotation = ha_overlap,
cluster_rows = FALSE, # para que se respete el orden de mayor a menor expresión
cluster_columns = FALSE,
show_column_names = FALSE,
row_names_gp = gpar(fontsize = 6),
#column_names_gp = gpar(fontsize = 3),
row_labels = labels_genes,
col = colorRamp2(c(-2, 0, 2), c("darkblue", "white", "red")),
column_title = paste("Overlap -", nombre_lista, "parecido celular")
)
print(heatmap_overlap)
# Heatmap forzando por genotipo
order_genotypes <- c("WT_Naive", "CC_T", "SC_T", "SC_T_REACT")
orden <- order(match(anno_info_overlap$Genotype, order_genotypes))
mat_overlap_genotipo <- mat_overlap[, orden]
anno_info_overlap_genotype <- anno_info_overlap[orden, ]
ha_overlap_genotype <- HeatmapAnnotation(df =  anno_info_overlap_genotype, col = col_lista)
heatmap_overlap_genotype <- Heatmap(
mat_overlap_genotipo,
name = "Expression",
top_annotation = ha_overlap_genotype,
cluster_rows = FALSE,
cluster_columns = FALSE,
show_column_names = FALSE,
row_names_gp = gpar(fontsize = 6),
#column_names_gp = gpar(fontsize = 3),
row_labels = labels_genes,
col = colorRamp2(c(-2, 0, 2), c("darkblue", "white", "red")),
column_title = paste("Overlap -", nombre_lista, "(genotipo)")
)
print(heatmap_overlap_genotype)
# Heatmap forzando por cluster y parecido celular
order_genotypes <- c("WT_Naive", "CC_T", "SC_T", "SC_T_REACT")
orden <- order(anno_info_overlap$Cluster, anno_info_overlap$PC1, match(anno_info_overlap$Genotype, order_genotypes))
mat_overlap_cluster <- mat_overlap[, orden]
anno_info_overlap_cluster <- anno_info_overlap[orden, ]
ha_overlap_cluster <- HeatmapAnnotation(df =  anno_info_overlap_cluster, col = col_lista)
heatmap_overlap_cluster <- Heatmap(
mat_overlap_cluster,
name = "Expression",
top_annotation = ha_overlap_cluster,
cluster_rows = FALSE,
cluster_columns = FALSE,
show_column_names = FALSE,
row_names_gp = gpar(fontsize = 6),
#column_names_gp = gpar(fontsize = 3),
row_labels = labels_genes,
col = colorRamp2(c(-2, 0, 2), c("darkblue", "white", "red")),
column_title = paste("Overlap -", nombre_lista, "(cluster)")
)
print(heatmap_overlap_cluster)
}
