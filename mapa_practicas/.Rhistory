plot(NA,NA,axes=FALSE,xlab="",ylab="",xlim=c(0,10),ylim=c(0,10))
yi<-6.5
text(11,4.5,labels="Nr of\ngenomes",adj=c(1,0),xpd=TRUE,font=2,cex=1.2)
